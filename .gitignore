# Python virtualenvs (anywhere)
.venv/
.venv-marker/
venv/

# Local tool/model caches (Ollama binary + pulled model weights, etc.)
.tools/

# Terraform (never commit state, plugin cache, or local vars — they hold
# plaintext secrets like random_password results, IPs, and account IDs)
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/terraform.tfvars
!**/terraform.tfvars.example

