aws_region    = "us-east-1"
project_name  = "physics-db-admin"
instance_type = "t3.micro"
key_name      = "physics-db"          # create in EC2 → Key pairs first
ssh_cidr      = "203.0.113.10/32"     # your public IP /32

admin_email = "you@example.com"
cors_origin = "https://d28e99c7v2289t.cloudfront.net"  # from deploy/aws/terraform output site_url

# Optional but recommended — HTTPS for the API (Caddy + Lets Encrypt on the instance).
# Point api.yourdomain.com A record → Elastic IP after terraform apply.
api_domain = ""
