APP_ENV=development
JWT_SECRET=
# In development, ALLOW_PUBLIC_REGISTRATION=true opens the editor to any email.
# In production, only ADMIN_ALLOWED_EMAILS may register/login.
ADMIN_ALLOWED_EMAILS=you@example.com
ALLOW_MOCK_BILLING=true
ALLOW_PUBLIC_REGISTRATION=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
MOCK_SUBSCRIPTION_DAYS=30

# --- AI tutor (public, unauthenticated POST /api/tutor/chat) ---
# Recommended for production: OpenRouter (https://openrouter.ai/keys)
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
# Optional override; default is google/gemini-2.5-flash-preview
# TUTOR_MODEL=google/gemini-2.5-flash-preview

# Cost/abuse controls (defaults shown):
# TUTOR_MAX_REPLY_TOKENS=700
# TUTOR_MAX_TURNS=16
# TUTOR_RATE_LIMIT_PER_HOUR=20
# TUTOR_DAILY_TOKEN_BUDGET=400000
# TUTOR_DAILY_REQUEST_BUDGET=600

# Alternative providers (offline pipeline / local dev only):
# LLM_PROVIDER=local
# LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# TUTOR_MODEL=qwen2.5:7b-instruct

# Production (required):
# APP_ENV=production
# JWT_SECRET=<random 32+ chars>
# ADMIN_ALLOWED_EMAILS=you@example.com
# ALLOW_MOCK_BILLING=false
# ALLOW_PUBLIC_REGISTRATION=false
# CORS_ORIGINS=https://your-admin-domain.com
